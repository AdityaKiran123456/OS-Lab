+static void PriorityTestThread(void* arg) {
+    int p = (int)(long)arg;
+    cout << "Running thread with priority: " << p << "\n";
+}
+
+void Kernel::PriorityTest() {
+    Thread* t1 = new Thread("low");
+    Thread* t2 = new Thread("medium");
+    Thread* t3 = new Thread("high");
+
+    t1->setPriority(1);
+    t2->setPriority(5);
+    t3->setPriority(10);
+
+    // Fork in reverse priority order to prove scheduler reorders them
+    t1->Fork((VoidFunctionPtr)PriorityTestThread, (void*)1);
+    t3->Fork((VoidFunctionPtr)PriorityTestThread, (void*)10);
+    t2->Fork((VoidFunctionPtr)PriorityTestThread, (void*)5);
+
+    kernel->currentThread->Yield();
+}
 
